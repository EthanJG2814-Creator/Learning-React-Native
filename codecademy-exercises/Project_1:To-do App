import React,{useState} from 'react';
import { TextInput, View, Text,Button, ScrollView} from 'react-native';
import { TestDataButton } from './components/TestDataButton';

interface Todo {
  id: number;
  text: string;
  completed: boolean;
}

export default function App() {
  const[todoText,setTodoText] = useState<String>("");
  const[todos,setTodos] = useState<Todo[]>([]);

  const addTodo = (): void => {
    if (todoText.trim() !== '') {
      const newTodo: Todo = {
        id: Date.now(),
        text: todoText,
        completed: false
      };
      setTodos([...todos, newTodo]);
      setTodoText('');
    }
  };

  const toggleTodo = (id: number): void => {
    setTodos(todos.map(todo => {
      if (todo.id === id) {
        return { ...todo, completed: !todo.completed };
      }
      return todo;
    }));
  };

  return (
    <View>
      <Text>My To-do List</Text>
      <TextInput
        placeholder ="Enter a new to-do"
        value = {todoText}
        onChangeText = {setTodoText}
      />
      <Button title = "Add To-do"
      onPress ={addTodo}
      />
      <TestDataButton onAddTestData={setTodos} />
      <Text>
        Task:
      </Text>
      <ScrollView style ={{height:400}}>
        {todos.length === 0?(
          //when array is empty reply to user
        <Text>No to-dos yet. Add one above!</Text>
       ) : (
        //when  array has todos map over each to do and display it
        todos.map((todo) => (
          <View Key={todo.id}>
            <Text onPress={() => toggleTodo(todo.id)}>
              {todo.completed ? "x" : "O"} {todo.text}
            </Text>
          </View>
        ))
       )}
      </ScrollView>
      
        <View>
          <Text>
            Total: {todos.length}
          </Text>
          <Text>
            Completed: {todos.filter(todo => todo.completed).length}
          </Text> 
        </View>
    </View>
  );
}
